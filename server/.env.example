# Auth0 (tenant)
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://roz-api

# Auth0 Management API M2M (utilisé par le script seed pour créer les comptes staff)
AUTH0_MGMT_CLIENT_ID=your-m2m-client-id
AUTH0_MGMT_CLIENT_SECRET=your-m2m-client-secret

# Les variables suivantes sont déjà définies dans docker-compose.yml
# DATABASE_URL, NODE_ENV, CLIENT_URL, PORT → ne pas les dupliquer ici
