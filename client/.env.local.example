# Auth0 (application SPA)
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_CLIENT_ID=your-auth0-spa-client-id
AUTH0_CLIENT_SECRET=your-auth0-spa-client-secret
AUTH0_AUDIENCE=https://roz-api

# Clé secrète aléatoire pour chiffrer la session Auth0
# Générer avec : openssl rand -hex 32
AUTH0_SECRET=replace-with-openssl-rand-hex-32

# Les variables suivantes sont déjà définies dans docker-compose.yml
# APP_BASE_URL, API_URL, NEXT_PUBLIC_API_URL → ne pas les dupliquer ici
